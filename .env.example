# ─── Sannad Tech - Variables d'environnement ──────────────────────────
# Copiez ce fichier en .env pour le développement local
# Sur Vercel, ajoutez ces variables dans Dashboard > Settings > Environment Variables

# Clé secrète Flask (changez-la !)
SECRET_KEY=changez-cette-cle-secrete

# ─── Base de données ─────────────────────────────────────────────────
# PostgreSQL (Vercel Postgres, Supabase, Neon...). Laissez vide pour SQLite en local.
# DATABASE_URL=postgresql://user:password@host:5432/postgres

# ─── Configuration SMTP (Gmail) ─────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=votre.email@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_DEFAULT_SENDER=Sannad Tech <contact@sannadtech.ma>
ADMIN_EMAIL=admin@sannadtech.ma

# ─── WhatsApp (bouton flottant) ──────────────────────────────────────
WHATSAPP_NUMBER=212600000000

# ─── Cloudinary (Stockage des photos) ───────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Admin ──────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
